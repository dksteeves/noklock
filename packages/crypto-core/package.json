{
  "name": "@soulchain/crypto-core",
  "version": "0.2.0",
  "description": "NoKLock cryptographic core — SLIP-39 secret splitting + Argon2id KDF + AEAD wrapping + Ed25519 manifest signing. Browser-and-Node, zero UI dependencies. All primitives sourced from the @noble family (paulmillr) — pure JS, no WASM.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./kdf": "./src/kdf.ts",
    "./aead": "./src/aead.ts",
    "./slip39": "./src/slip39.ts",
    "./manifest": "./src/manifest.ts",
    "./bip39": "./src/bip39.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/ciphers": "^1.0.0",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@scure/bip39": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "license": "BUSL-1.1",
  "private": true
}
