{
  "name": "@soulchain/storage-adapters",
  "version": "0.1.0",
  "description": "Pluggable storage backends for NoKLock encrypted shares — Dropbox, Google Drive, OneDrive, IPFS (Pinata), Arweave (Irys), and local file download.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./dropbox": "./src/dropbox.ts",
    "./google-drive": "./src/google-drive.ts",
    "./onedrive": "./src/onedrive.ts",
    "./ipfs-pinata": "./src/ipfs-pinata.ts",
    "./arweave-irys": "./src/arweave-irys.ts",
    "./local-file": "./src/local-file.ts"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
