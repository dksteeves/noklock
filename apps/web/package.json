{
  "name": "noklock-web",
  "version": "0.3.0",
  "description": "NoKLock progressive web app — vault enrolment (seed / sealed letter / document), restore, NoK management, license mint, heartbeat, Test-Prove function.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "validate-env": "node scripts/validate-env.mjs",
    "prebuild": "node scripts/validate-env.mjs && node scripts/gen-seo.mjs",
    "build": "tsc --noEmit && vite build",
    "postbuild": "node scripts/gen-prerender.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pressure": "vitest run --config vitest.pressure.config.ts"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.28.0",
    "@soulchain/crypto-core": "*",
    "@soulchain/storage-adapters": "*",
    "@tanstack/react-query": "^5.50.0",
    "@walletconnect/ethereum-provider": "^2.13.0",
    "permissionless": "^0.3.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.24.0",
    "viem": "^2.20.0",
    "wagmi": "^2.12.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0"
  },
  "license": "BUSL-1.1",
  "private": true
}
